{
  "name": "cogniux",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint src && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:firestore": "node scripts/check-firestore.mjs",
    "deploy:firestore-rules": "node scripts/deploy-firestore-rules.mjs",
    "deploy:firestore-indexes": "node scripts/deploy-firestore-rules.mjs indexes",
    "deploy:firestore": "node scripts/deploy-firestore-rules.mjs && node scripts/deploy-firestore-rules.mjs indexes"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.13.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.56.4",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.6.2",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-tools": "^14.27.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.2.3",
    "vitest": "^3.2.1"
  }
